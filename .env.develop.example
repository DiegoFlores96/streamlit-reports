# App
NAME_APP=Streamlit Reports
PASSWORD_ENCODE=utf-8
ENCODING=utf-8

# Security
JWT_SECRET_KEY=replace-with-a-strong-secret-for-develop
JWT_EXPIRE_MINUTES=60

# Database (choose one)
# Option 1: full SQLAlchemy URL
# DATABASE_URL=sqlite:///./reports.db

# Option 2: local sqlite file path (used when DATABASE_URL is empty)
DB_FILE=reports.db

# Data source
# Absolute path expected by dashboards/notebooks
PATH_TESTES_ARQUIVOS=C:/data

# Streamlit server
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
HOST_PORT=8501